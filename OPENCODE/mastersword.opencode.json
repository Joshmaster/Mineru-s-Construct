        "qwen/qwen3-32b": {
          "name": "Qwen3 32B"
        },
        "groq/compound": {
          "name": "Groq Compound"
        },
        "groq/compound-mini": {
          "name": "Groq Compound Mini"
        },
        "llama-3.1-8b-instant": {
          "name": "LLaMA 3.1 8B"
        },
        "allam-2-7b": {
          "name": "Allam 2 7B (leve)"
        }
      }
    },
    "ollama": {
      "api": "http://localhost:11434/v1",
