{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "api": "https://openrouter.ai/api/v1",
      "env": ["OPENROUTER_API_KEY"],
      "models": {
        "openai/gpt-oss-20b:free": { "name": "GPT OSS 20B (gratis, barato)" },
        "openai/gpt-oss-120b:free": { "name": "GPT OSS 120B (gratis)" },
        "google/gemma-4-31b-it:free": { "name": "Gemma 4 31B (gratis)" },
        "nvidia/nemotron-3-super-120b-a12b:free": { "name": "Nemotron 120B (gratis)" },
        "meta-llama/llama-3.3-70b-instruct:free": { "name": "LLaMA 3.3 70B (gratis)" }
      }
    },
    "groq": {
      "api": "https://api.groq.com/openai/v1",
      "env": ["GROQ_API_KEY"],
      "models": {
        "llama-3.3-70b-versatile": { "name": "LLaMA 3.3 70B (gratis)" },
        "moonshotai/kimi-k2-instruct": { "name": "Kimi K2 (gratis)" }
      }
    },
    "ollama": {
      "api": "http://localhost:11434/v1",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "qwen2.5:7b": { "name": "Qwen 2.5 7B (local)" }
      }
    }
  },
  "model": "openrouter/openai/gpt-oss-20b:free",
  "instructions": [
    "~/Agents/OPENCODE/roaming/LINK_PERSONA.md"
  ]
}
