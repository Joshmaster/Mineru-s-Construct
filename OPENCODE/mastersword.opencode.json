        },
        "google/gemma-4-31b-it:free": {
          "name": "Gemma 4 31B"
        },
        "google/gemma-4-26b-a4b-it:free": {
          "name": "Gemma 4 26B"
        },
        "inclusionai/ling-2.6-1t:free": {
          "name": "Ling 2.6 1T"
        },
        "openrouter/free": {
          "name": "OpenRouter Free (auto)"
        },
        "openrouter/owl-alpha": {
          "name": "Owl Alpha"
        },
        "liquid/lfm-2.5-1.2b-instruct:free": {
          "name": "LFM 1.2B (leve)"
        }
      }
    },
    "groq": {
