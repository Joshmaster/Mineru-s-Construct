#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

export OPENCODE_CONFIG="${OPENCODE_CONFIG:-$HOME/.config/opencode/opencode.json}"
export OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX="${OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX:-${MASTERSWORD_OUTPUT_TOKEN_MAX:-2048}}"

if [[ -z "${OPENROUTER_API_KEY:-}" ]]; then
  OPENROUTER_API_KEY="$(python3 - <<'PY'
from hyrule_env import OPENROUTER_KEYS
print(OPENROUTER_KEYS[0] if OPENROUTER_KEYS else "")
PY
)"
  export OPENROUTER_API_KEY
fi

python3 - <<'PY'
from watch_mastersword_queue import _ensure_config
_ensure_config()
PY

case "${1:-}" in
  models)
    python3 - <<'PY'
from watch_mastersword_queue import _modelos
for i, model in enumerate(_modelos(), 1):
    print(f"{i}. {model}")
PY
    ;;
  config)
    echo "$OPENCODE_CONFIG"
    ;;
  run)
    shift
    python3 mastersword_cli.py "$@"
    ;;
  "")
    exec opencode --model openrouter/openai/gpt-5.1 --dir "$(pwd)" --dangerously-skip-permissions
    ;;
  *)
    python3 mastersword_cli.py "$@"
    ;;
esac
