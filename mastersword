#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

export OPENCODE_CONFIG="${OPENCODE_CONFIG:-$HOME/.config/opencode/opencode.json}"
export OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX="${OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX:-${MASTERSWORD_OUTPUT_TOKEN_MAX:-2048}}"

_load_key() {
  python3 - "$1" <<'PY'
from pathlib import Path; import sys
sys.path.insert(0, str(Path.home() / 'Agents'))
try:
    import hyrule_env as e; keys = getattr(e, sys.argv[1], [])
    print(keys[0] if keys else "")
except: print("")
PY
}

[[ -z "${OPENROUTER_API_KEY:-}" ]] && OPENROUTER_API_KEY="$(_load_key OPENROUTER_KEYS)" && export OPENROUTER_API_KEY
[[ -z "${MISTRAL_API_KEY:-}"    ]] && MISTRAL_API_KEY="$(_load_key MISTRAL_KEYS)"       && export MISTRAL_API_KEY
[[ -z "${CEREBRAS_API_KEY:-}"   ]] && CEREBRAS_API_KEY="$(_load_key CEREBRAS_KEYS)"     && export CEREBRAS_API_KEY

python3 - <<'PY'
from watch_mastersword_queue import _ensure_config
_ensure_config()
PY

case "${1:-}" in
  models)
    python3 - <<'PY'
from watch_mastersword_queue import _modelos
for i, model in enumerate(_modelos(), 1):
    print(f"{i}. {model}")
PY
    ;;
  config)
    echo "$OPENCODE_CONFIG"
    ;;
  run)
    shift
    python3 mastersword_cli.py "$@"
    ;;
  "")
    exec opencode --model openrouter/openai/gpt-5.1 --dir "$(pwd)" --dangerously-skip-permissions
    ;;
  *)
    python3 mastersword_cli.py "$@"
    ;;
esac
